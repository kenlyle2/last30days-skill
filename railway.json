{
  "$schema": "https://schema.railway.app/railway-schema-v2.json",
  "deploy": {
    "startCommand": "python3 -m pip install -e . && uvicorn api:app --host 0.0.0.0 --port ${PORT:-8080}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "build": {
    "builder": "NIXPACKS"
  }
}
